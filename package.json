{
  "name": "discord-slash-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Web app + Discord slash-command bot: verified interactions endpoint, configurable rules, mirror-to-second-channel, and an admin dashboard.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "register-commands": "tsx scripts/register-commands.ts",
    "seed-admin": "tsx scripts/seed-admin.ts"
  },
  "prisma": {
    "seed": "tsx scripts/seed-admin.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "eslint-config-next": "^15.5.20",
    "jose": "^5.9.6",
    "next": "^15.5.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "dotenv": "^16.4.5",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
